DB_HOST=localhost
DB_PORT=3306
DB_USER=readonly_user_hogehogehoge
DB_PASSWORD=********
# テナント一覧を取得するベースDB（例：everdoc）
BASE_DATABASE=everdoc
# 取得対象のホスト名（SQLの where host = '...' 用）
TARGET_HOST=hostname.example.com
# 出力先ディレクトリ
OUTPUT_DIR=out

# BigQuery関連の設定
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json
BQ_PROJECT_ID=
# BigQuery dataset（例: worker）
BQ_DATASET=worker
OUTPUT_MODE=bigquery
# auto | insert | loadjob
BQ_WRITE_MODE=auto
# auto時にこの件数以上で load job を使う
BQ_LOAD_THRESHOLD=5000